{
  "name": "diaria-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pipeline Claude Code para produção da newsletter Diar.ia",
  "scripts": {
    "sync-sources": "tsx scripts/sync-sources.ts",
    "discover-rss": "tsx scripts/discover-rss.ts",
    "validate-feeds": "tsx scripts/validate-feeds.ts",
    "smoke": "tsx scripts/smoke-test.ts",
    "verify-facebook-posts": "tsx scripts/verify-facebook-posts.ts",
    "collect-edition-signals": "tsx scripts/collect-edition-signals.ts",
    "upload-images-public": "tsx scripts/upload-images-public.ts",
    "substitute-image-urls": "tsx scripts/substitute-image-urls.ts",
    "aggregate-costs": "tsx scripts/aggregate-costs.ts",
    "lint-newsletter-html": "tsx scripts/lint-newsletter-html.ts",
    "topic-cluster": "tsx scripts/topic-cluster.ts",
    "update-audience": "tsx scripts/update-audience.ts",
    "refresh-past-editions": "tsx scripts/refresh-past-editions.ts",
    "verify-accessibility": "tsx scripts/verify-accessibility.ts",
    "build-link-ctr": "tsx scripts/build-link-ctr.ts",
    "validate-agents": "tsx scripts/validate-agent-frontmatter.ts",
    "lint-agents": "tsx scripts/lint-agent-md.ts",
    "archive-editions": "tsx scripts/archive-editions.ts",
    "setup-hooks": "node -e \"const fs=require('fs');const src='scripts/hooks/pre-commit';const dst='.git/hooks/pre-commit';fs.copyFileSync(src,dst);fs.chmodSync(dst,'755');console.log('Hook instalado.');\"",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "fast-xml-parser": "^5.7.1",
    "papaparse": "^5.4.1",
    "puppeteer": "^24.42.0",
    "sharp": "^0.34.0",
    "tsx": "^4.19.0",
    "undici": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/papaparse": "^5.3.15",
    "typescript": "^5.6.0"
  }
}
