CLARICE_API_KEY=
GEMINI_API_KEY=

# OpenAI Images API (image gen — gpt-image-2 default)
# Só necessário se platform.config.json > image_generator = "openai".
# Chave em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Facebook Graph API (Stage 6 — publish-facebook.ts)
# Token de página com scope pages_manage_posts + pages_read_engagement
# Expira em 60 dias; regenerar em: https://developers.facebook.com/tools/explorer/
# Page ID: encontrar em https://www.facebook.com/diaria.br → Sobre → ID da página
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_API_VERSION=v25.0

# Beehiiv REST API (fetch-beehiiv-poll-stats.ts, beehiiv-sync.ts, refresh-dedup.ts)
# Chave em: https://app.beehiiv.com/settings/workspace/api
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=pub_b9534d43-9bc1-47cc-bddc-b98d8fa0ddf5

# Google OAuth (para Drive sync + Gmail inbox drain)
# Setup único: npx tsx scripts/oauth-setup.ts
# Criar credenciais em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Brevo API — digest mensal parceria Clarice (#653, #654)
# Chave em: app.brevo.com → Settings → SMTP & API → API Keys → Create API Key
# Permissões necessárias: email campaigns (create, send test) + contacts (read)
BREVO_CLARICE_API_KEY=

# Cloudflare Workers AI (image gen zero-cost — #88, #254)
# Só necessário se platform.config.json > image_generator = "cloudflare".
# Conta: https://dash.cloudflare.com (free)
# Token: https://dash.cloudflare.com/profile/api-tokens com scope "Workers AI"
# Account ID: visível em qualquer URL do dashboard dash.cloudflare.com/{account_id}/...
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Cloudflare KV write — push de dados pros Workers diaria-dashboard / poll / leaderboard
# (build-diaria-dashboard-data.ts --push, clarice-engagement-cohorts.ts, cloudflare-kv-upload.ts).
# Token com scope "Workers KV Storage:Edit" (+ Account). Mesmo Account ID acima.
# Usado pelo wrapper de schedule scripts/run-diaria-dashboard-push.cmd (ver docs/dashboard-schedule.md).
CLOUDFLARE_WORKERS_TOKEN=
# Namespace ID do KV do diaria-dashboard. Opcional: o wrapper passa --kv-namespace-id
# explicitamente; setar aqui só se for remover o flag do .cmd (ver docs/dashboard-schedule.md).
DASHBOARD_KV_NAMESPACE_ID=

# Make.com webhook para auto-publicação no LinkedIn (#506, #596)
# Cenário Make.com recebe POST com { text, image_url, scheduled_at, destaque, action, parent_destaque }.
# Scenario com Router: action="post" cria company post; action="comment" busca latest
# Diar.ia post + adiciona comment (#595).
# Setup: ver docs/make-linkedin-setup.md + docs/make-diaria-extend-comment.md (#595).
# **Tratar como secret** — qualquer um com a URL pode disparar publicações.
# Tem precedência sobre platform.config.json > publishing.social.linkedin.make_webhook_url
# (que deve ficar vazio em código versionado).
MAKE_LINKEDIN_WEBHOOK_URL=

# Make.com webhook para Pixel personal LinkedIn (#595)
# Scenario "Pixel LinkedIn" autenticado com vjpixel personal. Recebe payload
# { text, image_url, scheduled_at, destaque, action: "comment", parent_destaque }
# e adiciona comment ao último post Diar.ia. Único escopo: comment_pixel (T+8min).
# **NÃO é o mesmo URL do scenario Diar.ia** — auth e webhook URL separados.
# Setup: ver docs/make-pixel-linkedin-setup.md (#595).
# Esta variável é **opcional** localmente — Worker é quem realmente fira o webhook
# (Worker secret: `wrangler secret put MAKE_PIXEL_WEBHOOK_URL` em workers/linkedin-cron/).
MAKE_LINKEDIN_PIXEL_WEBHOOK_URL=

# Brave Search API (fetch-websearch-batch.ts — #1555 default desde 260529 #1560)
# Free tier: 2000 queries/mês (suficiente: ~16 queries/edição × 30 = 480/mês).
# Gerar em: https://brave.com/search/api/
# Default WEBSEARCH_BACKEND=brave — Path A 10× mais rápido + $0 vs agents Haiku.
# Fallback automático pra Path B (agents) quando BRAVE_API_KEY ausente.
# Rollback: setar WEBSEARCH_BACKEND=agents pra forçar Path B mesmo com API key presente.
BRAVE_API_KEY=
WEBSEARCH_BACKEND=brave

# MillionVerifier (verify-emails-mv.ts — #1297)
# Verifica listas de email (ex: T02 ex-assinantes) antes de mandar pro Brevo,
# pra não degradar a reputação do IP/domínio com bounce alto. Pay-as-you-go
# (~$1.90/1000) ou subscription (~$0.99/1000). Custo one-time.
# Pegar a key em: https://app.millionverifier.com → API
MILLION_VERIFIER_API_KEY=

# Telegram Bot API — plugin telegram@claude-plugins-official (ver docs/telegram-setup.md)
# Permite controlar/notificar a sessão do Claude Code via Telegram (channels).
# Token gerado pelo @BotFather no Telegram (/newbot). Formato: 123456789:AAH...
# O plugin também grava em ~/.claude/channels/telegram/.env após /telegram:configure;
# o env var tem precedência. Requer Bun instalado (curl -fsSL https://bun.sh/install | bash).
TELEGRAM_BOT_TOKEN=
