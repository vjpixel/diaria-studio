node_modules/
dist/
.env
.env.local
# data/ inteira mora no OneDrive (junction local) — nada vai pro repo.
# Antes do PR #1355 havia exceções intencionais aqui pra versionar audit
# trail editorial (data/editions/*/01-categorized.{md,json}, 01-approved.json
# e data/monthly/*/{prioritized.md,raw-destaques.json}). Foram removidas
# conscientemente — OneDrive sync + Drive sync cobrem reprodutibilidade
# entre máquinas. Não reverter pra exceções sem revisar essa decisão.
# Logs append-only por fonte (data/sources/*.jsonl) também moram aqui:
# crescem indefinidamente, valor analítico só local.
data/
# Scheduling lockfile (ephemeral por execução)
.claude/scheduled_tasks.lock
.DS_Store
.tmp/
# Cloudflare Wrangler local build/cache state (root + workers/*/.wrangler)
.wrangler/
# Tipos gerados por `wrangler types` — regenerável, não versionar
worker-configuration.d.ts
# #2020: artefatos de lint/review por edição — destino canônico é data/editions/{AAMMDD}/_internal/;
# padrões aqui são rede de segurança caso um agente escreva na raiz por engano
lint-result-*.json
review-result-*.json
